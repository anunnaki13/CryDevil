# ═══════════════════════════════════════════════════════════════════════════════
#  HOKIDRAW BOT — FILE KONFIGURASI LENGKAP
#  Salin file ini ke .env lalu isi sesuai data Anda:
#    cp .env.example .env && nano .env
# ═══════════════════════════════════════════════════════════════════════════════


# ── 1. ALAMAT WEBSITE ──────────────────────────────────────────────────────────
#  Jika domain berubah, cukup ganti nilai di bawah ini.
#  Konten/struktur halaman diasumsikan tetap sama.
#  Contoh: jika domain lama partai34848.com → diganti partai99999.com,
#  cukup ubah SITE_URL saja, tidak perlu ubah kode apapun.

SITE_URL=https://partai34848.com

#  Pool/pasaran ID (lihat di URL halaman game, format: p12345)
POOL_ID=p76368


# ── 2. AKUN LOGIN ──────────────────────────────────────────────────────────────

PARTAI_USERNAME=username_anda
PARTAI_PASSWORD=password_anda


# ── 3. OPENROUTER API (LLM PREDIKSI) ──────────────────────────────────────────
#  Daftar dan ambil API key di: https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

#  Model utama untuk prediksi (gratis/murah, cepat)
LLM_MODEL=google/gemini-2.0-flash-001

#  Model cadangan jika model utama gagal
LLM_FALLBACK_MODEL=anthropic/claude-sonnet-4-20250514

#  Kreativitas LLM: 0.0 = deterministik, 1.0 = paling random (rekomendasi: 0.3)
LLM_TEMPERATURE=0.3


# ── 4. NOMINAL BET ─────────────────────────────────────────────────────────────
#
#  Bot SELALU menggunakan Bet Full (payout x100). Tidak bisa diubah.
#
#  Cara hitung dari panel situs (IDR 1.000 = 1):
#    bet param = BASE_BET ÷ 1.000
#    BASE_BET=100  → bet=0.1 → total per kategori = 0.1 × 1.000 × 50 angka = Rp 5.000
#    BASE_BET=200  → bet=0.2 → total per kategori = 0.2 × 1.000 × 50 angka = Rp 10.000
#    BASE_BET=1000 → bet=1   → total per kategori = 1   × 1.000 × 50 angka = Rp 50.000
#
#  Bot pasang 2 bet per periode (Besar/Kecil + Genap/Ganjil):
#    BASE_BET=100 → Rp5.000 × 2 = Rp10.000 total taruhan/periode
#
#  Jika menang satu kategori:
#    Menang = BASE_BET × 100 (payout BET FULL) = Rp10.000
#    Modal  = Rp5.000 → Profit bersih = +Rp5.000
#
#  Nominal bet per ANGKA (IDR). Minimum Rp 100.

BASE_BET=100

#  Mode bet per periode:
#    double = 2 bet sekaligus (Besar/Kecil + Genap/Ganjil) ← DIREKOMENDASIKAN
#    single = 1 bet saja (pilih yang confidence LLM lebih tinggi)
BET_MODE=double


# ── 5. MARTINGALE ──────────────────────────────────────────────────────────────
#  BK (Besar/Kecil) dan GJ (Genap/Ganjil) punya level TERPISAH.
#  Menang salah satu → reset level dimensi itu ke 0, tidak pengaruh yang lain.
#
#  Nominal per ANGKA tiap level (IDR), pisahkan dengan koma.
#  Total per bet = level × 50 angka
#
#  Default 5 level:
#    Level 0: Rp 100/angka → bet=0.1 → Rp 5.000/bet   ← awal
#    Level 1: Rp 200/angka → bet=0.2 → Rp10.000/bet   ← setelah 3 loss berturut
#    Level 2: Rp 400/angka → bet=0.4 → Rp20.000/bet
#    Level 3: Rp 800/angka → bet=0.8 → Rp40.000/bet
#    Level 4: Rp1600/angka → bet=1.6 → Rp80.000/bet   ← ceiling
#
#  Contoh flat (tanpa martingale): 100
#  Contoh 3 level konservatif:    100,200,400

MARTINGALE_LEVELS=100,150,250,400,600,900,1300

#  Naik 1 level setiap berapa kekalahan BERTURUT-TURUT?
#  Contoh: 5 = naik level setelah 5 kalah berturut-turut
MARTINGALE_LOSS_THRESHOLD=5


# ── 6. MANAJEMEN UANG ──────────────────────────────────────────────────────────
#  Bot otomatis BERHENTI bet hari ini jika total kerugian mencapai limit ini.
#  Reset otomatis setiap tengah malam WIB.
#  Contoh: 200000 = berhenti jika sudah rugi Rp 200.000 hari ini

DAILY_LOSS_LIMIT=200000


# ── 7. TELEGRAM NOTIFIKASI ─────────────────────────────────────────────────────
#  Bot akan kirim notifikasi ke Telegram untuk setiap:
#  bet dipasang, hasil menang/kalah, summary harian, dan alert error.
#
#  Cara setup:
#  1. Chat @BotFather di Telegram → /newbot → ambil TOKEN
#  2. Kirim pesan ke bot Anda, lalu buka:
#     https://api.telegram.org/bot<TOKEN>/getUpdates
#     Ambil "chat":{"id": ...} → itu CHAT_ID Anda
#
#  Kosongkan kedua nilai ini jika tidak mau pakai Telegram.

TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789


# ── 8. JADWAL / TIMING ─────────────────────────────────────────────────────────
#  Hokidraw buka 24x sehari, setiap jam (00:00, 01:00, 02:00, dst.)
#  Bot pasang bet di menit ke-N setelah jam buka.

#  Mulai pasang bet di menit ke berapa setelah jam buka?
#  Contoh: 5 → bot pasang bet di 00:05, 01:05, 02:05, ...
BET_START_MINUTE=5

#  Batas akhir boleh pasang bet (menit ke berapa sebelum tutup)?
#  Contoh: 50 → bot tidak pasang bet jika sudah lewat menit :50
BET_STOP_MINUTE=50


# ── 9. LANJUTAN (opsional, sudah ada default wajar) ────────────────────────────

#  Interval polling cek result baru (detik). Default: 120 (2 menit)
# POLL_INTERVAL=120

#  Maksimal percobaan polling sebelum skip periode. Default: 10
# MAX_POLL_ATTEMPTS=10

#  Interval validasi ulang sesi login (detik). Default: 1800 (30 menit)
# SESSION_CHECK_INTERVAL=1800
