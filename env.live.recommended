# CryDevil — recommended live baseline

INSTANCE_NAME=crydevil
INSTANCE_LABEL=CryDevil

SITE_URL=https://partai34848.com
POOL_ID=p76368

PARTAI_USERNAME=isi_username_anda
PARTAI_PASSWORD=isi_password_anda

OPENROUTER_API_KEY=sk-or-isi_api_key_anda
LLM_MODEL=minimax/minimax-m2.5
LLM_FALLBACK_MODEL=anthropic/claude-sonnet-4-20250514
LLM_TEMPERATURE=0.25

# Analisis dan recovery
PREDICTION_EVAL_WINDOW=50
KNOWLEDGE_BASE_HISTORY_LIMIT=400
BACKLOG_RECOVERY_LIMIT=1000
HISTORY_FETCH_MAX_PAGES=100

# Modal konservatif awal
OPERATION_MODE=sedang
BASE_BET=100
BET_MODE=single
MIN_CONFIDENCE_TO_BET=0.62

# 6 slot martingale terpisah
MARTINGALE_LEVELS=100,200,400,800,1600
MARTINGALE_STEP_LOSSES=3
DAILY_LOSS_LIMIT=200000

# Lokasi state
STATE_DIR=.
DB_PATH=data/hokidraw.db
LOG_PATH=logs/bot.log

# Telegram
TELEGRAM_BOT_TOKEN=isi_token_telegram
TELEGRAM_CHAT_ID=isi_chat_id
# TELEGRAM_MESSAGE_THREAD_ID=10
TELEGRAM_COMMANDS_ENABLED=true
TELEGRAM_PREDICT_COOLDOWN_SECONDS=60

# Jadwal
BET_START_MINUTE=5
BET_STOP_MINUTE=50
POLL_INTERVAL=120
MAX_POLL_ATTEMPTS=10
SESSION_CHECK_INTERVAL=1800
